# EVM Gateway configuration reference.
# This file mirrors the runtime env surface in internal/config.DefaultConfig.

# Global
WEB3INJ_ENV=local
WEB3INJ_LOG_FORMAT=json
WEB3INJ_LOG_VERBOSE=false

# Chain connections
# Leave WEB3INJ_CHAIN_ID blank to trust the chain ID reported by CometBFT.
WEB3INJ_CHAIN_ID=
WEB3INJ_COMET_RPC=http://localhost:26657
WEB3INJ_GRPC_ADDR=localhost:9090

# Indexer
WEB3INJ_EARLIEST_BLOCK=127250000
WEB3INJ_FETCH_JOBS=4
WEB3INJ_DATA_DIR=~/.evm-gateway
WEB3INJ_DB_BACKEND=goleveldb
WEB3INJ_ALLOW_GAPS=true
WEB3INJ_ENABLE_SYNC=true
WEB3INJ_MIN_GAS_PRICES=160000000inj
WEB3INJ_SHUTDOWN_TIMEOUT=10s

# JSON-RPC
WEB3INJ_JSONRPC_ENABLE=true
WEB3INJ_JSONRPC_API=eth,net,web3,debug
WEB3INJ_JSONRPC_ADDRESS=0.0.0.0:8545
WEB3INJ_JSONRPC_WS_ADDRESS=0.0.0.0:8546
WEB3INJ_JSONRPC_ENABLE_UNSAFE_CORS=false
WEB3INJ_JSONRPC_GAS_CAP=25000000
WEB3INJ_JSONRPC_EVM_TIMEOUT=5s
WEB3INJ_JSONRPC_TXFEE_CAP=1
WEB3INJ_JSONRPC_FILTER_CAP=200
WEB3INJ_JSONRPC_FEEHISTORY_CAP=100
WEB3INJ_JSONRPC_LOGS_CAP=10000
WEB3INJ_JSONRPC_BLOCK_RANGE_CAP=10000
WEB3INJ_JSONRPC_HTTP_TIMEOUT=30s
WEB3INJ_JSONRPC_HTTP_IDLE_TIMEOUT=120s
WEB3INJ_JSONRPC_ALLOW_UNPROTECTED_TXS=false
WEB3INJ_JSONRPC_MAX_OPEN_CONNECTIONS=0
WEB3INJ_JSONRPC_RETURN_DATA_LIMIT=512000

# OpenTelemetry (gotracer)
# Leave collector values blank unless tracing is enabled.
# Set WEB3INJ_GOTRACER_COLLECTOR_ENABLE_TLS=false for plain local OTLP gRPC receivers such as SigNoz on :4317.
WEB3INJ_GOTRACER_ENABLED=false
WEB3INJ_GOTRACER_COLLECTOR_DSN=
WEB3INJ_GOTRACER_COLLECTOR_AUTHORIZATION=
WEB3INJ_GOTRACER_COLLECTOR_AUTHORIZATION_HEADER=
WEB3INJ_GOTRACER_COLLECTOR_ENABLE_TLS=true
WEB3INJ_GOTRACER_CLUSTER_ID=inj
